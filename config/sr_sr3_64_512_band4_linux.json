{
  "name": "E_step_on_qb",
  "info": "using PAN-MS as condition, to generate fusion result",
  "phase": "val",
  // train or val
  "gpu_ids": [
    3
  ],
  "path": {
    //set the path
    "log": "logs",
    "tb_logger": "tb_logger",
    "results": "results",
    "checkpoint": "checkpoint",
    "resume": "/home/qlt/EM_sharpening/experiments/E_step_on_qb_230910_153309/checkpoint/I15436800_E900"
  },
  "datasets": {
    "train": {
      "dataroot": "/data/qlt/pancollection/training_data/train_qb_data.h5",
      "batch_size": 32,
      "num_workers": 8,
      "use_shuffle": true,
      "data_len": -1
    },
    "val": {
      "dataroot": "/data/qlt/pancollection/test_data/QB/test_qb_data_FR.h5",
      "data_len": -1
    }
  },
  "model": {
    "which_model_G": "easy",
    "beta_schedule": {
      // use munual beta_schedule for acceleration
      "train": {
        "schedule": "cosine",
        "n_timestep": 1000
      },
      "val": {
        "schedule": "cosine",
        "n_timestep": 1000
      }
    },
    "init_type":"kaiming",
     "unet": {
      "in_channel": 4,
      "channel_multiplier": [
        32,
        64,
        128,
        256
      ]
    },
    "diffusion": {
      "image_size": 64,
      "conditional": true,
      "loss_type": "l2"
    }
  },
  "train": {
    "n_epochs": 1000,
    "val_freq": 100,
    "save_checkpoint_freq": 100,
    "print_freq": 1,
    "optimizer": {
      "lr": 3e-4
    }
  }
}



